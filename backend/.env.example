# Groq API Key (get one free at https://console.groq.com/keys)
GROQ_API_KEY=your_api_key_here

# PostgreSQL Database URL
# For local dev: postgresql://user:password@localhost:5432/recipe_extractor
# For Render: set from the Render PostgreSQL internal URL
DATABASE_URL=your_database_url_here

# (Production only) Frontend URL for CORS
FRONTEND_URL=
